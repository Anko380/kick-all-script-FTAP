            destroyBlobman()
            kickAllInProgress = false
            kickAllRequestedAt = 0
            kickAllLastSitState = false
            kickAllShouldRemount = false
            kickAllHasSatThisRequest = false
            KickAllProcessed = {}
            
            Rayfield:Notify({
                Title = "停止",
                Content = "処理を強制停止しました",
                Duration = 2
            })
        end
    end
})

